<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Industrial-sized track for the seekbar -->
    <item android:gravity="center_vertical" android:height="100dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A1814" />
            <corners android:radius="50dp" />
            <stroke android:width="10dp" android:color="#2B2824" />
        </shape>
    </item>
    <!-- Massive hardware scale marks -->
    <item android:gravity="center_vertical" android:height="120dp">
        <rotate android:fromDegrees="90">
            <clip>
                <shape android:shape="line">
                    <stroke android:width="20dp" android:color="#2B2824" android:dashWidth="12dp" android:dashGap="160dp" />
                </shape>
            </clip>
        </rotate>
    </item>
</layer-list>
